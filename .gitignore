data/dunbrack/

# Epitope pipeline (MaSIF → ScanNet → PPI-hotspot → epitope-viz)
# Covers all outputs and caches under data/epitopes/: patches.parquet,
# patches_scannet.parquet, patches_final.parquet, *.diagnostics.json,
# *.errors.log, MaSIF/ScanNet scratch + cached docker outputs, Modal hotspot
# cache (hotspot_scores.json + .cache_sig sidecars), MaSIF debug JSONs, .pml
# scripts, and the staged-PDB scratch.
data/epitopes/

# Per-run PDB list inputs (e.g. targets_a.txt, targets_3erd.txt)
data/targets*.txt

